# ================================================================
# FYCHEO DEMO — Variables de Entorno
# ================================================================
# Copia este archivo como .env y rellena con los datos de tu
# proyecto Supabase dedicado a la demo.
# ================================================================

# Supabase — Proyecto Demo (DIFERENTE al proyecto de producción)
VITE_SUPABASE_URL=https://XXXXXXXXXXXXX.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ID de la empresa demo (obtenido tras ejecutar 02_demo_company_and_teams.sql)
# SELECT id FROM companies WHERE name = 'Distribuciones Martínez S.A.';
VITE_DEMO_COMPANY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Credenciales de las cuentas demo (crea estos usuarios en Supabase Auth)
VITE_DEMO_ADMIN_EMAIL=demo.admin@fycheo-demo.com
VITE_DEMO_ADMIN_PASSWORD=FycheoDemo2024!
VITE_DEMO_MANAGER_EMAIL=demo.manager@fycheo-demo.com
VITE_DEMO_MANAGER_PASSWORD=FycheoDemo2024!

# PIN para el panel de administración (/fyadmin) — cámbialo por uno seguro
VITE_ADMIN_PIN=tu-pin-secreto
